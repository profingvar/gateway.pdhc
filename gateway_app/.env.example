# gateway.pdhc — environment template
#
# Copy to .env and fill in real values. .env is gitignored.
# On miserver this file is operator-edited; on the Mac it's developer-edited.

# ── Database ────────────────────────────────────────────────────────
POSTGRES_USER=gateway_pdhc
POSTGRES_PASSWORD=change-me-strong-random
POSTGRES_DB=gateway_pdhc_db
DATABASE_URL=postgresql://gateway_pdhc:change-me-strong-random@db:5432/gateway_pdhc_db

# ── Flask ───────────────────────────────────────────────────────────
FLASK_SECRET_KEY=change-me-strong-random
COMPOSE_PROJECT_NAME=gateway_app

# ── Upstream services ──────────────────────────────────────────────
REQUEST_SERVICE_URL=https://request.pdhc.se/api/v1
REQUEST_INTERNAL_SERVICE_KEY=ask-operator
CONTRACT_SERVICE_URL=https://contract.pdhc.se
CONTRACT_INTERNAL_SERVICE_KEY=ask-operator
PROVIDER_SERVICE_URL=http://localhost:9070/api/v1

# ── SSO ────────────────────────────────────────────────────────────
SSO_BASE_URL=https://sso.pdhc.se
SSO_CLIENT_ID=ask-operator
SSO_CLIENT_SECRET=ask-operator
SSO_CALLBACK_URL=https://gateway.pdhc.se/auth/callback

# ── Bootstrap ───────────────────────────────────────────────────────
BOOTSTRAP_SU_API_KEY=ask-operator

# ── Downstream cdr.pdhc (cdr1) forwarder ───────────────────────────
# CDR1 is the platform's single source of truth (simulates Cambio CDR).
# Gateway forwards every concept-resolved inbound observation onward via
# the cdr_forwarder APScheduler worker. Flip CDR_FORWARDING_ENABLED to
# 'true' after first deploy + backfill.
CDR_BASE_URL=http://cdr_pdhc_app:9046
CDR_TIMEOUT_SECONDS=30
CDR_FORWARDING_ENABLED=false
CDR_FORWARDING_INTERVAL_SECONDS=60
# SSOT phase 5 (#284): when true, forwarder deletes the
# InboundObservation row after delivery. Flip true after running
# `flask delete-already-delivered` for the historical backlog.
CDR_FORWARDING_DELETE_AFTER_DELIVERY=false
# Must match cdr.pdhc/cdr_app/app/api/auth.py's
# GATEWAY_PDHC_SERVICE_KEY config AND (since #291) dashboard.pdhc's
# GATEWAY_PDHC_SERVICE_KEY config — operator copies the same value to
# both .env files.
GATEWAY_PDHC_SERVICE_KEY=ask-operator

# Analyse layer (dashboard.pdhc) — gateway's /api/v1/observations
# search proxies here since #291 (was cdr1 from #282). Federated
# cohort reads across CDR1–6 are analyse's job; cdr1 only owns
# per-point storage.
ANALYSE_BASE_URL=http://host.docker.internal:9027
ANALYSE_TIMEOUT_SECONDS=30
